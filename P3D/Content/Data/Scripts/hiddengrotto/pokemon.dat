version=2
@pokemon.cry(<register.value(grottopokemon<level.filename>)>)
@battle.Setvar(hiddenabilitychance,100)
:if:<register.value(grottoshiny<level.filename>)>=S
	@battle.wild(<register.value(grottopokemon<level.filename>)>,<register.value(grottolevel<level.filename>)>,1,,,<register.value(grottopokemongender<level.filename>)>)
:else
	@battle.wild(<register.value(grottopokemon<level.filename>)>,<register.value(grottolevel<level.filename>)>,0,,,<register.value(grottopokemongender<level.filename>)>)
:endif
@register.registertime(grottoempty<level.filename>,<system.random(24,72)>,hours)
@register.unregister(grottopokemon<level.filename>,str)
@register.unregister(grottoshiny<level.filename>,str)
@register.unregister(grottoactive<level.filename>,str)
@register.unregister(grottolevel<level.filename>,int)
@register.unregister(grottopokemongender<level.filename>,int)
@npc.remove(0)
:end