version=2
:if:<register.registered(powerplant_magneton_trade)>=True
	@Text.show(So, how is my~old Magneton doing?)
:else
	@Text.show(I collect Pokémon.*Do you have Dugtrio?*Want to trade it for Magneton?)
	@Options.show(Yes,No)
		:when:Yes
			@Pokemon.NPCTrade(51|82||1|||50082|Forest|5|2007|at Route 6|caught|Maggie|Okay lets do this!|You don't want to~trade? Aww...|powerplant_magneton_trade|<system.token(trade_screen_trade_TradedWithNPC)>*Yay, I got myself a Dugtrio!~Thanks!)
		:when:No
			@Text.show(You don't want to~trade? Aww...)
	:endwhen
:endif
:end