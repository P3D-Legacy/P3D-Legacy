version=2
	:if:<radio.currentchannel>=<system.token(pokegear_screen_radio_PokeFlute_Name)>
		@text.show(The Pokégear was placed~near the sleeping~Snorlax...*...*Snorlax woke up!)
		@pokemon.cry(143)
		@level.wait(30)
		@battle.wild(143,50)
		@entity.remove(0)
		@register.register(snorlaxawake)
		@register.register(snorlaxawake_respawn)
	:else
		@pokemon.cry(143)
		@text.show(Snorlax is snoring~peacefully...)
	:endif
:end