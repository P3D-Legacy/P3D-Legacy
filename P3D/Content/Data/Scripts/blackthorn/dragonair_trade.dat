version=2
:if:<register.registered(blackthorn_dragonair_trade)>=true
:then
@Text.show(How is that~Dodrio I~traded you doing?*Your Dragonair's so cute!)
:else
@Text.show(Dragonair's cute,~but I don't have*it. Do you have~Dragonair?*Want to trade it~for my Dodrio?)
@Options.show(Yes,No)
:when:Yes
@Pokemon.NPCTrade(148|85||1|||00283|Emy|5|106|Route 22|caught at|Dodris|OK, connecting...|You don't don't want to~trade? Oh, darn...|blackthorn_dragonair_trade|<system.token(trade_screen_trade_TradedWithNPC)>*Wow! Thank you!~I always wanted~Dragonair)
:when:No
@Text.show(You don't want to~trade? Oh, darn...)
:endwhen
:endif
:end