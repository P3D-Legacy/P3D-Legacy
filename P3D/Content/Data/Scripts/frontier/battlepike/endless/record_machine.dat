version=2
:if:<register.registered(frontier_battlepike_challenge_values_created)>=false
	@text.show(No data recorded for~Endless Mode.)
:else
	@text.show(A machine which displays~record data for~Endless Mode:)
	@options.show(Lv. 50,Lv. 100,Cancel)
	:when:Lv. 50
		@text.show(Your record for:~Lv. 50, Endless Mode:~<register.value(battlepike_endless_50_best)> rooms.)
	:when:Lv. 100
		@text.show(Your record for:~Lv. 100, Endless Mode:~<register.value(battlepike_endless_100_best)> rooms.)
	:when:Cancel
		@text.show(Record machine~shutting down.)
	:endwhen
:endif
:end