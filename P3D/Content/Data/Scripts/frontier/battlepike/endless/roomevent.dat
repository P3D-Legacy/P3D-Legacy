zversion=2
@register.change(pike_room_count_temp,<register.value(pike_room_count_temp)>+1)
:select:<register.value(pikeroom<level.filename>)>
	:when:0
		#enter room, get statused, full control - Done
		@storage.set(string,pikestatuspokemon,Kirlia)
		:select:<system.random(0,19)>
			:when:0
				@storage.set(integer,pikestatusattack,0)
			:when:1
				@storage.set(integer,pikestatusattack,1)
				@npc.wearskin(1,[POKEMON|N]356)
				@storage.set(string,pikestatuspokemon,Dusclops)
			:when:2;3
				@storage.set(integer,pikestatusattack,2)
			:when:4;5;6;7
				@storage.set(integer,pikestatusattack,3)
			:when:8;9;10;11;12
				@storage.set(integer,pikestatusattack,4)
				@npc.wearskin(1,[POKEMON|N]356)
				@storage.set(string,pikestatuspokemon,Dusclops)
			:when:13;14;15;16;17;18;19
				@storage.set(integer,pikestatusattack,5)
				@npc.wearskin(1,[POKEMON|N]315)
				@storage.set(string,pikestatuspokemon,Roselia)
		:endwhen
		:select:<player.position(x)>
			:when:0
				@npc.warp(1,1,0,0)
				@npc.warp(2,0,0,0)
			:when:1
				@npc.warp(1,0,0,0)
				@npc.warp(2,1,0,0)
		:endwhen
		@player.move(0)
		@text.show(Oh, my!)
		@npc.setspeed(1,3)
		@npc.move(1,1)
		:select:<player.position(x)>
			:when:0
				@npc.turn(1,1)
			:when:1
				@npc.turn(1,3)
		:endwhen
		@npc.move(1,1)
		@npc.turn(1,2)
		@npc.move(1,1)
		@text.show(Watch out!)
		:select:<register.value(pike_class)>
			:when:0
				@storage.set(integer,pikestatusattempts,1)
				@storage.set(integer,pikestatusmon0,<system.random(0,2)>)
			:when:1
				@storage.set(integer,pikestatusattempts,2)
					:select:<system.random(0,2)>
						:when:0
							@storage.set(integer,pikestatusmon0,0)
							@storage.set(integer,pikestatusmon1,1)
						:when:1
							@storage.set(integer,pikestatusmon0,0)
							@storage.set(integer,pikestatusmon1,2)
						:when:2
							@storage.set(integer,pikestatusmon0,2)
							@storage.set(integer,pikestatusmon1,1)
					:endwhen
			:when:2
				@storage.set(integer,pikestatusattempts,3)
				@storage.set(integer,pikestatusmon0,0)
				@storage.set(integer,pikestatusmon1,1)
				@storage.set(integer,pikestatusmon2,2)
		:endwhen
		@storage.set(integer,pikestatusdone,0)
		:select:<storage.get(integer,pikestatusattack)>
			:when:0
				@text.show(Kirlia used Will-O-Wisp!)
				:while:<storage.get(integer,pikestatusattempts)>><storage.get(integer,pikestatusdone)>
					:if:<pokemon.status(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=none
						:if:<pokemon.istype(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>,fire)>=false
							:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=41
								:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=199
									:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=213
										@pokemon.setstatus(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>,brn)
									:endif
								:endif
							:endif
						:endif
					:endif
					@storage.update(integer,pikestatusdone,+,1)					
				:endwhile
			:when:1
				@text.show(Dusclops used Will-O-Wisp!)
				:while:<storage.get(integer,pikestatusattempts)>><storage.get(integer,pikestatusdone)>
					:if:<pokemon.status(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=none
						:if:<pokemon.istype(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>,fire)>=false
							:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=41
								:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=199
									:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=213
										@pokemon.setstatus(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>,brn)
									:endif
								:endif
							:endif
						:endif
					:endif
					@storage.update(integer,pikestatusdone,+,1)					
				:endwhile
			:when:2
				@text.show(Kirlia used Hypnosis!)
				:while:<storage.get(integer,pikestatusattempts)>><storage.get(integer,pikestatusdone)>
					:if:<pokemon.status(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=none
						:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=15
							:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=72
								:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=175
									:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=213
										@pokemon.setstatus(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>,slp)
									:endif
								:endif
							:endif
						:endif
					:endif
					@storage.update(integer,pikestatusdone,+,1)					
				:endwhile
			:when:3
				@text.show(Kirlia used Thunder Wave!)
				:while:<storage.get(integer,pikestatusattempts)>><storage.get(integer,pikestatusdone)>
					:if:<pokemon.status(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=none
						:if:<pokemon.istype(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>,electric)>=false <and> <pokemon.istype(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>,ground)>=false
							:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=7
								:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=213
									@pokemon.setstatus(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>,prz)
								:endif
							:endif
						:endif
					:endif
					@storage.update(integer,pikestatusdone,+,1)					
				:endwhile
			:when:4
				@text.show(Dusclops used Ice Beam!)
				:while:<storage.get(integer,pikestatusattempts)>><storage.get(integer,pikestatusdone)>
					:if:<pokemon.status(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=none
						:if:<pokemon.istype(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>,ice)>=false
							:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=40
								:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=213
									@pokemon.setstatus(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>,frz)
								:endif
							:endif
						:endif
					:endif
					@storage.update(integer,pikestatusdone,+,1)					
				:endwhile
			:when:5
				@text.show(Roselia used Toxic!)
				:while:<storage.get(integer,pikestatusattempts)>><storage.get(integer,pikestatusdone)>
					:if:<pokemon.status(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=none
						:if:<pokemon.istype(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>,poison)>=false <and> <pokemon.istype(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>,steel)>=false
							:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=17
								:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=257
									:if:<not><pokemon.ability(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>)>=213
										@pokemon.setstatus(<storage.get(integer,pikestatusmon<storage.get(integer,pikestatusdone)>)>,bpsn)
									:endif
								:endif
							:endif
						:endif
					:endif
					@storage.update(integer,pikestatusdone,+,1)					
				:endwhile
		:endwhen
		@npc.move(2,1)
		@npc.turn(1,0)
		@text.show(Look here!~That's quite enough!)
		:select:<player.position(x)>
			:when:0
				@npc.turn(1,3)
			:when:1
				@npc.turn(1,1)
		:endwhen
		@npc.move(1,-1)
		@npc.move(2,1)
		:select:<player.position(x)>
			:when:0
				@npc.turn(2,1)
			:when:1
				@npc.turn(2,3)
		:endwhen
		@level.wait(25)
		@npc.turn(2,2)
		@text.show(I must apologize to you...*My <storage.get(string,pikestatuspokemon)> has~a timid nature...*It attacks without warning~if it is startled by another~person...*Are you and your [POKE]mon~all right?)
		:end
	:when:1
		#old hat man standing in front of exit,manual approach for script. - Done
		@npc.warp(11,~,0,~)
	:when:2
		#trainer comes in direct ahead, starts battle with text, then walks back out
		@storage.set(integer,trainer_id,<system.random(0,307)>)

		@npc.spawn(<player.position(x)>,0,-1,0,,<npc.trainertexture(frontier\battletower\<storage.get(integer,trainer_id)>)>,0,2,0,20,Still)

		@player.move(0)
		@npc.move(20,2)
		@text.show(<battle.intromessage(frontier\battletower\<storage.get(integer,trainer_id)>)>)

		@battle.setvar(canreceiveexp,0)
		@battle.setvar(canuseitems,0)
		@battle.setvar(canblackout,0)

		@battle.setvar(frontiertrainer,<register.value(pike_class)>)
		@battle.trainer(frontier\battletower\<storage.get(integer,trainer_id)>)
		
		:if:<battle.won>=true
			@npc.turn(20,0)
			@npc.move(20,4)
			@npc.remove(20)
		:else
			@script.start(frontier\battlepike\endless\lost)
		:endif
	:when:3
		#Maid approaches, full heals, and leaves - Done
		@npc.warp(31,<player.position(x)>,0,~)
		@player.move(0)
		@npc.move(31,2)
		@text.show(Welcome... You must be~commended for your luck...*Your [POKE]mon shall be~restored to full health...)
		@sound.play(healing,1)
		@pokemon.heal
		@text.show(I urge you to enjoy the rest~of your Battle Choice~Challenge...)
		@npc.turn(31,0)
		@npc.move(31,4)
	:when:4
		#warp to wild room, full control
		@player.warp(frontier\battlepike\wildroom.dat,4,0.1,16)
	:when:5
		#Maid+trainer(m-left, t-center), trainer approaches, trainer leaves, maid approaches and heals fully, then leaves
		@storage.set(integer,trainer_id,<system.random(0,307)>)
		:select:<player.position(x)>
			:when:0
				@npc.warp(31,1,0,~)
				@npc.warp(51,0,0,~)
			:when:1
				@npc.warp(31,0,0,~)
				@npc.warp(51,1,0,~)
		:endwhen
		@npc.wearskin(51,<npc.trainertexture(frontier\battletower\<storage.get(integer,trainer_id)>)>)
		@player.move(0)
		@text.show(Welcome...*Here, we will have you battle~a somewhat-tough trainer...)
		@npc.move(51,2)
		@battle.setvar(canreceiveexp,0)
		@battle.setvar(canuseitems,0)
		@battle.setvar(canblackout,0)
		@battle.setvar(frontiertrainer,2)
		@battle.trainer(frontier\battletower\<storage.get(integer,trainer_id)>)
		:if:<battle.won>=true
			@npc.turn(51,0)
			@npc.move(51,3)
			:select:<player.position(x)>
				:when:0
					@npc.turn(31,1)
				:when:1
					@npc.turn(31,3)
			:endwhen
			@npc.move(31,1)
			@npc.turn(31,2)
			@npc.move(31,2)
			@text.show(How wonderful...*To honor your victory,~your [POKE]mon shall be~restored to full health...*I urge you to enjoy~the rest of your~Battle Choice challenge...)
			@sound.play(healing,1)
			@pokemon.heal
			@npc.turn(31,0)
			@npc.move(31,3)
		:else
			@script.start(frontier\battlepike\endless\lost)
		:endif
	:when:6
		#random npc who will say a one liner - Done
		@register.change(pike_npc,<system.random(5,29)>)
		@npc.wearskin(61,<register.value(pike_npc)>)
		@npc.warp(61,~,0,~)
		@script.start(frontier\battlepike\chatter)
	:when:7
		#double Approach, battle, leave
		@storage.set(integer,trainer_id,<system.random(0,306)>)
		:select:<player.position(x)>
			:when:0
				@npc.spawn(0,0,-1,0,,<npc.trainertexture(frontier\battletower\<storage.get(integer,trainer_id)>)>,0,2,0,70,Still)
				@npc.spawn(1,0,-1,0,,<npc.trainertexture(frontier\battletower\<math.int(<storage.get(integer,trainer_id)>+1)>)>,0,2,0,71,Still)
			:when:1
				@npc.spawn(1,0,-1,0,,<npc.trainertexture(frontier\battletower\<storage.get(integer,trainer_id)>)>,0,2,0,70,Still)
				@npc.spawn(0,0,-1,0,,<npc.trainertexture(frontier\battletower\<math.int(<storage.get(integer,trainer_id)>+1)>)>,0,2,0,71,Still)
		:endwhen


		@player.move(0)
		@npc.moveasync(70,2)
		@npc.move(71,2)
		@text.show(<battle.intromessage(frontier\battletower\<storage.get(integer,trainer_id)>)>)

		@battle.setvar(canreceiveexp,0)
		@battle.setvar(canuseitems,0)
		@battle.setvar(canblackout,0)

		@battle.setvar(frontiertrainer,<register.value(pike_class)>)
		@battle.trainer(frontier\battletower\<storage.get(integer,trainer_id)>)
		
		:if:<battle.won>=true
			@npc.turn(70,0)
			@npc.turn(71,0)
			@npc.moveasync(70,4)
			@npc.move(71,4)
			@npc.remove(70)
			@npc.remove(71)
		:else
			@script.start(frontier\battlepike\endless\lost)
		:endif
:endwhen
@storage.clear
:end