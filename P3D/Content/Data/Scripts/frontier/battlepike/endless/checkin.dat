version=2
@text.show(You are currently in~room <register.value(pike_room_count_temp)>...*Will you continue with~your challenge?)
@options.show(Yes,No)
	:when:No
		@text.show(Would you like to pause~your challenge and resume~it later?)
		@options.show(Yes,No)
			:when:Yes
				@register.unregister(resumedinpike,int)
				@register.register(savinginpike)
				@player.save
				@player.quitgame(true)
			:when:No
				@text.show(So you want to quit~your challenge entirely?)
				@options.show(Yes,No)
					:when:Yes
						@script.start(frontier\battlepike\endless\lost)
					:when:No
				:endwhen
		:endwhen
:endwhen
:end