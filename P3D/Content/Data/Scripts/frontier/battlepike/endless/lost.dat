version=2
@screen.fadeout
@player.warp(frontier\battlepike\main.dat,6,0.1,2)
@level.update
@player.turnto(0)
@screen.fadein
@text.show(Your challenge has ended...)

@pokemon.add(<register.value(temp_pike_endless_poke1)>)
@pokemon.add(<register.value(temp_pike_endless_poke2)>)
@pokemon.add(<register.value(temp_pike_endless_poke3)>)

@register.unregister(temp_pike_endless_poke1,str)
@register.unregister(temp_pike_endless_poke2,str)
@register.unregister(temp_pike_endless_poke3,str)

@pokemon.calcstats(0)
@pokemon.calcstats(1)
@pokemon.calcstats(2)

@pokemon.heal

:if:<register.value(pike_room_count_temp)>>14
	@storage.set(integer,get_bp,<math.floor(3+(<register.value(pike_room_count_temp)>)/7)>)
	@text.show(In recognition of your~amazing luck, we award~you these Battle Points...)
	@player.addbp(<storage.get(integer,get_bp)>)
	@text.show(<player.name> got <storage.get(integer,get_bp)> BP!*You now have <player.bp> BP.)
	:if:<register.value(pike_room_count_temp)>><register.value(battlepike_endless_<register.value(pike_level)>_best)>
		@register.change(battlepike_endless_<register.value(pike_level)>_best,<register.value(pike_room_count_temp)>)
		@text.show(Congratulations!~You beat your high score.*Your new high score is~<register.value(pike_room_count_temp)> rooms.)
	:endif
:endif

@register.change(battlepike_endless_<register.value(pike_level)>_previous_streak,0)
@register.change(battlepike_endless_<register.value(pike_level)>_class,0)

@register.unregister(piketype,str)
@register.unregister(pike_level,int)
@register.unregister(pike_class,int)
@register.unregister(wildlevel,INT)
@register.unregister(pike_room_count_temp,INT)

@register.unregister(pike_endless_level_0,int)
@register.unregister(pike_endless_level_1,int)
@register.unregister(pike_endless_level_2,int)

@register.unregister(pike_npc,INT)
@register.unregister(pikeroom0,INT)
@register.unregister(pikeroom1,INT)
@register.unregister(pikeroom2,INT)
@register.unregister(pikehintspot,INT)
@register.unregister(pikehint,INT)
@register.unregister(pikehinted,INT)
@register.unregister(wildlevel,INT)
@register.unregister(wildspecial,str)
@register.unregister(pikelucynext)

	@text.show(I shall record your results.~Please wait...)
	@player.save
	
	@text.show(We look forward to seeing~you on another occasion...)
	@storage.clear
	

:endscript