version=2
:select:<system.random(0,41)>
	:when:0
		@npc.setadditionalvalue(61,I am lost~I need a Helping Hand.)
	:when:1
		@npc.setadditionalvalue(61,I've no sense of~where I am!)
	:when:2
		@npc.setadditionalvalue(61,What should I do now?)
	:when:3
		@npc.setadditionalvalue(61,This is too exciting for me!)
	:when:4
		@npc.setadditionalvalue(61,Did you make a mistake?)
	:when:5
		@npc.setadditionalvalue(61,It's mean and awful in here!)
	:when:6
		@npc.setadditionalvalue(61,I am so tired~of this place.)
	:when:7
		@npc.setadditionalvalue(61,I quite enjoy~this challenge.)
	:when:8
		@npc.setadditionalvalue(61,Look at how I Tackle this!)
	:when:9
		@npc.setadditionalvalue(61,Ready to give up yet?)
	:when:10
		@npc.setadditionalvalue(61,Oh no! Who are you?)
	:when:11
		@npc.setadditionalvalue(61,I've been wandering~about forever...)
	:when:12
		@npc.setadditionalvalue(61,I think I will give up...)
	:when:13
		@npc.setadditionalvalue(61,What should I do next?)
	:when:14
		@npc.setadditionalvalue(61,I can win with my~Sheer Cold genius!)
	:when:15
		@npc.setadditionalvalue(61,Won't someone cool show up?)
	:when:16
		@npc.setadditionalvalue(61,I can't take this any more.)
	:when:17
		@npc.setadditionalvalue(61,Oh no! Not another trainer!)
	:when:18
		@npc.setadditionalvalue(61,It has to be left next.)
	:when:19
		@npc.setadditionalvalue(61,I don't know if it's okay.)
	:when:20
		@npc.setadditionalvalue(61,It must be over soon right?)
	:when:21
		@npc.setadditionalvalue(61,Waaah! It wasn't this way!)
	:when:22
		@npc.setadditionalvalue(61,There is no give up in me!)
	:when:23
		@npc.setadditionalvalue(61,What will come after this?)
	:when:24
		@npc.setadditionalvalue(61,My pokemon are too tired...)
	:when:25
		@npc.setadditionalvalue(61,A trainer after another...)
	:when:26
		@npc.setadditionalvalue(61,My pokemon are strong~to poison!)
	:when:27
		@npc.setadditionalvalue(61,Go on. I can't anymore.)
	:when:28
		@npc.setadditionalvalue(61,I just want to go home!)
	:when:29
		@npc.setadditionalvalue(61,Lalala lalala!~I am awesome lalala!)
	:when:30
		@npc.setadditionalvalue(61,You think this is easy?)
	:when:31
		@npc.setadditionalvalue(61,Maybe it's right next~I think.)
	:when:32
		@npc.setadditionalvalue(61,Toxic is a terrible thing~isn't it?)
	:when:33
		@npc.setadditionalvalue(61,Every trainer here~is too weak!)
	:when:34
		@npc.setadditionalvalue(61,Do you like steel pokemon?)
	:when:35
		@npc.setadditionalvalue(61,I am not going to make it.)
	:when:36
		@npc.setadditionalvalue(61,I am just so confused!)
	:when:37
		@npc.setadditionalvalue(61,Yeehaw!~This place is a pushover!)
	:when:38
		@npc.setadditionalvalue(61,I haven't been in~a battle yet!)
	:when:39
		@npc.setadditionalvalue(61,I am going to power on!)
	:when:40
		@npc.setadditionalvalue(61,This is totally easy~isn't it?)
	:when:41
		@npc.setadditionalvalue(61,This battle game~is awesome!)
:endwhen
:end