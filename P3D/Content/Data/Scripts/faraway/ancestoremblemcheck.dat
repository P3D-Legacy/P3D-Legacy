version=2
:if:<register.registered(battlemew)>=True
	:if:<register.registered(achievedancestor)>=False
		@player.achieveemblem(ancestor)
		@register.register(achievedancestor)
	:endif
:endif
	:if:<register.registered(shinymew)>=false
		@register.register(shinymew,bool,false)
		:if:<system.random(1,<math.floor(<pokemon.mastershinyrate>/2)>)>=1
			@register.change(shinymew,true)
		:endif
	:endif
	:if:<register.value(shinymew)>=true
		@npc.wearskin(0,[POKEMON|S]151)
	:endif
:endif
:end